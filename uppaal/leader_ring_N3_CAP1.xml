<nta>
	<declaration>const int N = 3;
const int CAP = 1;
const int MAX_PID = 1;

typedef int[0, N-1] pid_t;
typedef int[0, N] msg_t;
typedef int[0, CAP] size_t;

msg_t id[N] = {1, 3, 2};

bool leader[N];
int[0, N] leader_count = 0;
bool wrong_leader = false;

msg_t buffer[N][CAP];
size_t size[N];

pid_t succ(pid_t i) {
    return (i + 1) % N;
}

bool can_receive(pid_t c) {
    return size[c] &gt; 0;
}

bool can_send(pid_t c) {
    return size[c] &lt; CAP;
}

msg_t front(pid_t c) {
    return buffer[c][0];
}

void push(pid_t c, msg_t v) {
    buffer[c][size[c]] = v;
    size[c]++;
}

void pop(pid_t c) {
    int k;

    k = 0;

    while (k &lt; size[c] - 1) {
        buffer[c][k] = buffer[c][k + 1];
        k++;
    }

    buffer[c][size[c] - 1] = 0;
    size[c]--;
}

void forward_msg(pid_t i, msg_t m) {
    push(succ(i), m);
    pop(i);
}

void discard(pid_t i) {
    pop(i);
}

void elect(pid_t i) {
    pop(i);

    if (i != MAX_PID) {
        wrong_leader = true;
    }

    leader[i] = true;
    leader_count++;
}
</declaration>
